# Public-safe example. Copy to USER_CONFIG.env outside version control before editing real values.
OBJECTIVE=Prepare a guarded Qwopus 27B GSPO-style RL run and stop after validation unless long training is explicitly enabled.
EXECUTION_MODE=local
SSH_HOST=<ssh-host-alias>
PROJECT_ROOT=<repository-root>
MODEL_ID=Jackrong/Qwopus3.6-27B-v2
BASE_TUTORIAL_PATH=train_code/Qwopus3.6-27B-GSPO/README.md
RL_SCRIPT_PATH=train_code/Qwopus3.6-27B-GSPO/qwopus3_6_27b_gspo_training.py
DATASET_PATH=train_code/Qwopus3.6-27B-GSPO/examples/sample_dataset_format.jsonl
OUTPUT_DIR=<output-directory>
ALGORITHM=GSPO
CONTEXT_LENGTH=4096
NUM_GENERATIONS=2
LEARNING_RATE=5e-6
MAX_STEPS=20
DRY_RUN=true
ALLOW_LONG_TRAINING=false
ALLOW_HF_UPLOAD=false
ALLOW_DESTRUCTIVE_ACTIONS=false
WANDB_MODE=disabled
