# Public-safe example. Copy to USER_CONFIG.env outside version control before editing real values.
OBJECTIVE=Prepare a Qwen MTP GGUF release locally, run preflight first, and stop before upload unless separately authorized.
SOURCE_REPO=owner/target-qwen-finetune
MTP_SOURCE_REPO=owner/matching-base-qwen-with-mtp
OUTPUT_REPO=owner/target-qwen-mtp-gguf
WORK_ROOT=./qwen-mtp-gguf-work
LLAMA_CPP=./qwen-mtp-env/llama.cpp
FILENAME_PREFIX=target-qwen-MTP
QUANT_FORMATS=q4_k_m,q5_k_m,q8_0,bf16
UPLOAD_STRATEGY=local-only
ALLOW_HF_UPLOAD=false
CLEANUP_AFTER_UPLOAD=false
TOKEN_ENV=HF_TOKEN
